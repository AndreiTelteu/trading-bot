# Server Configuration
PORT=5001
# Supply three different login principals. Values are intentionally blank.
DATABASE_URL=
MIGRATION_DATABASE_URL=
LEDGER_DATABASE_URL=
PARITY_DATABASE_URL=
# Compose reads credentials from files; values below are paths, not secrets.
POSTGRES_PASSWORD_FILE=
MIGRATION_DATABASE_URL_FILE=
RUNTIME_DATABASE_PASSWORD_FILE=
LEDGER_DATABASE_PASSWORD_FILE=
PARITY_DATABASE_PASSWORD_FILE=
RUNTIME_DATABASE_URL_FILE=
LEDGER_DATABASE_URL_FILE=
PARITY_DATABASE_URL_FILE=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=5m
SECRET_KEY=your-secret-key-here
AUTH_USERNAME=operator
AUTH_PASSWORD=replace-with-a-strong-password
GOVERNANCE_ADMIN_USERS=operator

# Stage 08 authority envelope (safe legacy defaults)
STAGE08_FLAG_SCHEMA_VERSION=stage08-flags-v1
STAGE08_LEDGER_AUTHORITY=legacy
STAGE08_SHARED_ENGINE=off
STAGE08_NEW_BACKTEST=off
STAGE08_POINT_IN_TIME_UNIVERSE=off
STAGE08_CANDIDATE_STRATEGY=off
STAGE08_DUAL_RUN=off
# Required only for limited_live/full_live; must identify an exact Stage 07 deployment.
STAGE08_STAGE07_CONTEXT=
# Stage 08 backup/restore uses libpq service names, not URLs. Supply the
# source, restore-admin, and (outside --test-mode) target-runtime record
# services through the execution environment; do not put credentials here.
STAGE08_SOURCE_SERVICE=
STAGE08_RESTORE_SERVICE=
STAGE08_RECORD_SERVICE=

# Trading Configuration
DEFAULT_BALANCE=400
DEFAULT_CURRENCY=USDT

# Binance API (optional - for live trading)
BINANCE_API_KEY=your-binance-api-key
BINANCE_SECRET=your-binance-secret

# Redis (optional - for caching)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
